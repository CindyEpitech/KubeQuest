# Build-context / image slimming — keep these out of the image entirely.
# vendor is rebuilt (prod-only) in the composer stage; node_modules isn't used.
.git
.gitignore
.gitattributes
.dockerignore
Dockerfile
docker-compose.yaml

vendor
node_modules

# Dev/test/CI cruft
tests
phpunit.xml
.styleci.yml
.editorconfig
README.md
README.pdf
webpack.mix.js
package.json
package-lock.json

# Local env / secrets must never bake into the image
.env
.env.*
!.env.example

# Laravel runtime artifacts (regenerated in the container)
storage/logs/*.log
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/views/*
bootstrap/cache/*.php
